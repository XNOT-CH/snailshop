// file: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- ตารางผู้ใช้งาน (Users) ---
model User {
  id            String    @id @default(uuid())
  name          String?   // Display name
  username      String    @unique
  email         String?   // Optional email
  password      String
  image         String?   @db.Text // Profile image URL
  role          String    @default("USER") // USER, MODERATOR, SELLER, ADMIN
  permissions   String?   @db.Text // JSON array of permission strings
  phone         String?   // เบอร์มือถือ
  phoneVerified Boolean   @default(false) // ยืนยันเบอร์มือถือแล้วหรือไม่
  emailVerified Boolean   @default(false) // ยืนยันอีเมลแล้วหรือไม่

  // ข้อมูลส่วนตัว
  firstName     String?   // ชื่อ (ภาษาไทย)
  lastName      String?   // นามสกุล (ภาษาไทย)
  firstNameEn   String?   // ชื่อ (ภาษาอังกฤษ)
  lastNameEn    String?   // นามสกุล (ภาษาอังกฤษ)

  // ที่อยู่ในการออกใบกำกับภาษี
  taxFullName   String?   // ชื่อ - สกุล
  taxPhone      String?   // หมายเลขโทรศัพท์
  taxAddress    String?   @db.Text // ที่อยู่
  taxProvince   String?   // จังหวัด
  taxDistrict   String?   // อำเภอ
  taxSubdistrict String?  // ตำบล
  taxPostalCode String?   // รหัสไปรษณีย์

  // ที่อยู่ในการจัดส่งของรางวัล
  shipFullName  String?   // ชื่อ - สกุล
  shipPhone     String?   // หมายเลขโทรศัพท์
  shipAddress   String?   @db.Text // ที่อยู่
  shipProvince  String?   // จังหวัด
  shipDistrict  String?   // อำเภอ
  shipSubdistrict String? // ตำบล
  shipPostalCode String?  // รหัสไปรษณีย์

  creditBalance Decimal   @default(0.00) @db.Decimal(10, 2)
  pointBalance  Int       @default(0)  // Point balance for rare items
  totalTopup    Decimal   @default(0.00) @db.Decimal(10, 2) // ยอดเติมเงินสะสม (ไม่หักออก)
  lifetimePoints Int      @default(0)  // พอยต์สะสมตลอดชีพ
  
  orders        Order[]
  topups        Topup[]
  sessions      Session[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  gachaRollLogs GachaRollLog[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ตาราง Session (สำหรับ Session Management) ---
model Session {
  id            String    @id @default(uuid())
  token         String    @unique @db.VarChar(255)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  lastActivity  DateTime  @default(now())
  userAgent     String?   @db.Text
  ipAddress     String?   @db.VarChar(45)
  
  createdAt     DateTime  @default(now())
}

// --- ตาราง API Keys (สำหรับ External Access) ---
model ApiKey {
  id            String    @id @default(uuid())
  name          String    // ชื่อ API Key (เช่น "Mobile App", "Partner Integration")
  key           String    @unique @db.VarChar(64) // Hashed API key
  keyPrefix     String    @db.VarChar(8) // First 8 chars for identification
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions   String?   @db.Text // JSON array of allowed permissions
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  
  @@index([keyPrefix])
}

// --- ตาราง Audit Log (บันทึกกิจกรรมสำคัญ) ---
model AuditLog {
  id            String    @id @default(uuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String    // เช่น "LOGIN", "LOGOUT", "CREATE_PRODUCT", "DELETE_USER"
  resource      String?   // เช่น "Product", "User", "Order"
  resourceId    String?   // ID ของ resource ที่ถูกกระทำ
  details       String?   @db.Text // JSON รายละเอียดเพิ่มเติม
  ipAddress     String?   @db.VarChar(45)
  userAgent     String?   @db.Text
  status        String    @default("SUCCESS") // SUCCESS, FAILURE
  
  createdAt     DateTime  @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// --- ตารางสินค้า (Products) ---
model Product {
  id            String    @id @default(uuid())
  name          String
  description   String?   @db.Text
  price         Decimal   @db.Decimal(10, 2)
  discountPrice Decimal?  @db.Decimal(10, 2)
  imageUrl      String?
  category      String
  currency      String    @default("THB")  // THB or POINT
  
  secretData    String    @db.Text
  stockSeparator String  @default("newline") // newline, doubleline, triple-dash, custom
  isSold        Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  sortOrder     Int       @default(0)
  
  orderId       String?   @unique
  order         Order?    @relation(fields: [orderId], references: [id])

  gachaRewards  GachaReward[]
  gachaRollLogs GachaRollLog[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ตารางคำสั่งซื้อ (Orders) ---
model Order {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  product       Product?
  givenData     String?   @db.Text // รหัสสินค้าที่ให้ลูกค้า (encrypted)
  totalPrice    Decimal   @db.Decimal(10, 2)
  status        String    @default("COMPLETED")
  purchasedAt   DateTime  @default(now())
}

// --- ตารางเติมเงิน (Topups / TopUpRequests) ---
model Topup {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  amount          Decimal   @db.Decimal(10, 2)
  proofImage      String?   @db.Text // Base64 or URL รูปสลิป
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  transactionRef  String?   @unique // EasySlip transaction reference
  senderName      String?   // ชื่อผู้โอน
  senderBank      String?   // ธนาคารผู้โอน
  rejectReason    String?   // เหตุผลที่ปฏิเสธ
  receiverName    String?   // ชื่อผู้รับ
  receiverBank    String?   // ธนาคารผู้รับ
  createdAt       DateTime  @default(now())
}

// --- ตารางตั้งค่าเว็บไซต์ (Site Settings) ---
model SiteSettings {
  id              String    @id @default(uuid())
  heroTitle       String
  heroDescription String    @db.Text
  announcement    String?   @db.Text
  
  // Banner Images (External URLs)
  bannerImage1    String?   @db.Text
  bannerTitle1    String?
  bannerSubtitle1 String?
  
  bannerImage2    String?   @db.Text
  bannerTitle2    String?
  bannerSubtitle2 String?
  
  bannerImage3    String?   @db.Text
  bannerTitle3    String?
  bannerSubtitle3 String?
  
  // Logo
  logoUrl         String?   @db.Text
  
  // Background Image
  backgroundImage String?   @db.Text
  
  // Homepage Section Toggles
  showAllProducts Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// --- ศูนย์ช่วยเหลือ (Help Center) ---
model HelpArticle {
  id            String    @id @default(uuid())
  question      String    @db.Text
  answer        String    @db.Text
  category      String    @default("general")
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ข่าวสารและโปรโมชั่น (News & Promotions) ---
model NewsArticle {
  id            String    @id @default(uuid())
  title         String
  description   String    @db.Text
  imageUrl      String?   @db.Text
  link          String?   // URL สำหรับ "อ่านเพิ่มเติม"
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- โค้ดส่วนลด (Promo Codes) ---
model PromoCode {
  id            String    @id @default(uuid())
  code          String    @unique              // โค้ดที่ลูกค้าใช้ (e.g. "SALE50")
  discountType  String    @default("PERCENTAGE") // PERCENTAGE or FIXED
  discountValue Decimal   @db.Decimal(10, 2)   // ส่วนลด (% หรือ บาท)
  minPurchase   Decimal?  @db.Decimal(10, 2)   // ยอดขั้นต่ำ
  maxDiscount   Decimal?  @db.Decimal(10, 2)   // ส่วนลดสูงสุด (สำหรับ %)
  usageLimit    Int?                           // จำนวนครั้งที่ใช้ได้ (null = ไม่จำกัด)
  usedCount     Int       @default(0)          // จำนวนที่ใช้แล้ว
  startsAt      DateTime  @default(now())      // เริ่มใช้ได้เมื่อ
  expiresAt     DateTime?                      // หมดอายุเมื่อ (null = ไม่หมดอายุ)
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ตั้งค่า Footer Widget ---
model FooterWidgetSettings {
  id          String    @id @default(uuid())
  isActive    Boolean   @default(true)  // เปิด/ปิดการแสดงผล
  title       String    @default("เมนูลัด")  // หัวข้อ widget
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- ลิงก์ใน Footer Widget ---
model FooterLink {
  id           String    @id @default(uuid())
  label        String    // ข้อความที่โชว์
  href         String    // ลิงก์ไปที่
  openInNewTab Boolean   @default(false)  // เปิดแท็บใหม่
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// --- แถบนำทางหลัก (Main Navigation) ---
model NavItem {
  id        String   @id @default(uuid())
  label     String   // ชื่อเมนูที่แสดง
  href      String   // เส้นทาง URL
  icon      String?  // ชื่อ icon (optional)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- การตั้งค่าสกุลเงินพิเศษ (Currency Settings) ---
model CurrencySettings {
  id          String   @id @default("default")
  name        String   @default("พอยท์")      // ชื่อที่แสดง
  symbol      String   @default("💎")         // ไอคอน/สัญลักษณ์
  code        String   @default("POINT")      // รหัส (ไม่เปลี่ยน)
  description String?  @db.Text               // คำอธิบาย
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// --- Pop-up ประชาสัมพันธ์ (Announcement Popups) ---
model AnnouncementPopup {
  id            String    @id @default(uuid())
  title         String?                   // ชื่อ/หัวข้อ (สำหรับ admin)
  imageUrl      String    @db.Text        // URL รูปภาพ (1500x1500px)
  linkUrl       String?   @db.Text        // URL เมื่อคลิกที่ popup
  sortOrder     Int       @default(0)     // ลำดับการแสดง
  isActive      Boolean   @default(true)
  dismissOption String    @default("show_always") // show_always หรือ hide_1_hour
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- ยศแอดมิน (Admin Roles) ---
model Role {
  id          String    @id @default(uuid())
  name        String    @unique          // ชื่อยศ (เช่น "แอดมินผู้ช่วย")
  code        String    @unique          // รหัสยศ (เช่น "ASSISTANT_ADMIN")
  iconUrl     String?   @db.Text         // URL ไอคอนยศ
  description String?                    // คำอธิบาย
  permissions String?   @db.Text         // JSON array of permissions
  sortOrder   Int       @default(0)
  isSystem    Boolean   @default(false)  // ยศระบบ (ลบไม่ได้ เช่น USER, ADMIN)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- หมวดหมู่กาชา (Gacha Categories) ---
model GachaCategory {
  id        String         @id @default(uuid())
  name      String                                  // ชื่อหมวดหมู่
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)

  machines  GachaMachine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- ตู้กาชาแต่ละใบ (Gacha Machines) ---
model GachaMachine {
  id            String   @id @default(uuid())
  name          String                                // ชื่อตู้กาชา
  description   String?  @db.Text                     // คำอธิบายตู้กาชา
  imageUrl      String?  @db.Text                     // รูปปก
  gameType      String   @default("SPIN_X")           // SPIN_X = สุ่มตัว X, GRID_3X3 = 3x3
  categoryId    String?
  category      GachaCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costType      String   @default("FREE")             // FREE, CREDIT, POINT
  costAmount    Decimal  @default(0) @db.Decimal(10, 2)
  dailySpinLimit Int     @default(0)
  tierMode      String   @default("PRICE")
  isActive      Boolean  @default(true)
  isEnabled     Boolean  @default(true)
  sortOrder     Int      @default(0)

  rewards       GachaReward[]
  rollLogs      GachaRollLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoryId])
}

// --- ตั้งค่าระบบกาชา (Gacha Settings) ---
model GachaSettings {
  id              String   @id @default("default")
  isEnabled       Boolean  @default(true)          // เปิด/ปิดระบบกาชา
  costType        String   @default("FREE")        // FREE, CREDIT, POINT
  costAmount      Decimal  @default(0) @db.Decimal(10, 2) // ราคาต่อครั้ง
  dailySpinLimit  Int      @default(0)             // 0 = ไม่จำกัด
  tierMode        String   @default("PRICE")       // PRICE = จัดตามราคา
  updatedAt       DateTime @updatedAt
}

// --- รางวัลในกาชา (Admin-managed reward pool) ---
model GachaReward {
  id        String   @id @default(uuid())

  // ประเภทรางวัล: PRODUCT | CREDIT | POINT
  rewardType      String   @default("PRODUCT")

  // สำหรับรางวัลแบบ PRODUCT
  productId String?  @unique
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  // สำหรับรางวัลแบบ CREDIT / POINT
  rewardName      String?            // ชื่อรางวัล เช่น "เครดิต 50 บาท"
  rewardAmount    Decimal? @db.Decimal(10, 2) // จำนวนเครดิต/พอยต์
  rewardImageUrl  String?  @db.Text  // URL รูปภาพแสดงในกริด

  tier        String   @default("common") // common, rare, epic, legendary
  probability Decimal  @default(1) @db.Decimal(6, 2) // โอกาสได้รับ (%)
  isActive    Boolean  @default(true)

  // FK to GachaMachine (null = legacy global pool)
  gachaMachineId  String?
  gachaMachine    GachaMachine? @relation(fields: [gachaMachineId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gachaMachineId])
}

// --- ประวัติการสุ่มกาชา (ใช้สำหรับจำกัดครั้ง/วัน) ---
model GachaRollLog {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  rewardName    String?           // ชื่อรางวัล (สำหรับ CREDIT/POINT หรือชื่อสินค้า)
  rewardImageUrl String? @db.Text // URL รูปภาพรางวัล

  tier          String   // common, rare, epic, legendary
  selectorLabel String?  // L1..L4 / R1..R4
  costType      String   // FREE, CREDIT, POINT
  costAmount    Decimal  @default(0) @db.Decimal(10, 2)

  // FK to GachaMachine (null = legacy global)
  gachaMachineId  String?
  gachaMachine    GachaMachine? @relation(fields: [gachaMachineId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([gachaMachineId])
}