# TiDB Cloud (mysql2 connection string)
# Format: mysql://USER:PASSWORD@HOST:4000/DATABASE
DATABASE_URL=mysql://USERNAME:PASSWORD@HOST:4000/DATABASE

# NextAuth v5
# Generate with: npx auth secret
AUTH_SECRET=REPLACE_WITH_OUTPUT_OF_npx_auth_secret
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to true in dev if you get UntrustedHost errors (127.0.0.1 vs localhost)
AUTH_TRUST_HOST=true

# AES-256 encryption key
# Supported formats: 64 hex chars, 32-byte UTF-8 string, or base64 for 32 bytes
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS
# Optional key ID for newly encrypted data
ENCRYPTION_KEY_ID=current
# Optional previous keys for decryption during key rotation
# Format: old1=64_HEX_OR_BASE64_KEY;old2=64_HEX_OR_BASE64_KEY
ENCRYPTION_PREVIOUS_KEYS=

# CSRF protection secret (64 hex chars)
CSRF_SECRET=REPLACE_WITH_64_HEX_CHARS

# EasySlip payment verification token
# Optional: if omitted, topup requests fall back to manual review (PENDING)
EASYSLIP_TOKEN=REPLACE_WITH_EASYSLIP_TOKEN

# Resend email API key (optional, but required for email receipts)
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY

# Cloudflare Turnstile (bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET_KEY

# Upstash Redis (rate limiting / cache)
# Required in production if you want cache/rate limit persistence.
UPSTASH_REDIS_REST_URL=REPLACE_WITH_UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_UPSTASH_REDIS_REST_TOKEN

# CORS allowed origin
# Set this to your production frontend origin before deploy.
ALLOWED_ORIGIN=https://your-domain.com

# Protect cron/admin automation endpoints in production
CRON_SECRET=REPLACE_WITH_CRON_SECRET

# Cube.js analytics (optional)
NEXT_PUBLIC_CUBEJS_API_URL=http://localhost:4000/cubejs-api/v1
NEXT_PUBLIC_CUBEJS_API_TOKEN=REPLACE_WITH_CUBEJS_API_TOKEN
