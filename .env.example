# TiDB Cloud (mysql2 connection string)
# Format: mysql://USER:PASSWORD@HOST:4000/DATABASE
DATABASE_URL=mysql://root: rootpassword@localhost:3307/my_game_store

# NextAuth v5
# Generate with: npx auth secret
AUTH_SECRET=REPLACE_WITH_OUTPUT_OF_npx_auth_secret
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to true in dev if you get UntrustedHost errors (127.0.0.1 vs localhost)
AUTH_TRUST_HOST=true

# AES-256 encryption key (64 hex chars)
ENCRYPTION_KEY=change-me-32-chars-secret-key123

# CSRF protection secret (64 hex chars)
CSRF_SECRET=change-me-32-chars-csrf-secret!!

# EasySlip payment verification token
EASYSLIP_TOKEN=your-easyslip-token-here

# Cloudflare Turnstile (bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=3x00000000000000000000FF
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Upstash Redis (rate limiting / cache)
# Required in production if you want cache/rate limit persistence.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# CORS allowed origin
# Set this to your production frontend origin before deploy.
ALLOWED_ORIGIN=

# Cube.js analytics (optional)
NEXT_PUBLIC_CUBEJS_API_URL=http://localhost:4000/cubejs-api/v1
NEXT_PUBLIC_CUBEJS_API_TOKEN=
